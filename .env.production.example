# 生产环境配置模板
# 复制此文件为 .env.production 并填写实际值

# ===========================================
# 安全相关（生产环境必须修改！）
# ===========================================

# 数据库密码 (请修改为强密码)
DB_PASSWORD=YourSecurePassword2026!

# Redis 密码 (请修改为强密码)
REDIS_PASSWORD=YourSecurePassword2026!

# JWT 签名密钥（请使用随机长字符串，至少 32 字符）
# 生成方法：openssl rand -base64 32
JWT_SECRET=YourSuperSecretJWTKey2026!ChangeMe!

# 前端访问地址（不带末尾斜杠）
FRONTEND_URL=https://your-domain.com

# 初始管理员账号（首次启动若该邮箱不存在则自动创建，留空则跳过）
ADMIN_INIT_EMAIL=
ADMIN_INIT_USERNAME=
ADMIN_INIT_PASSWORD=

# 管理员邮箱（逗号分隔，多个地址用英文逗号隔开）
# 示例：ADMIN_EMAILS=admin@example.com,another@example.com
ADMIN_EMAILS=

# SMTP 邮件配置（用于发送注册/重置密码验证码）
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USER=
SMTP_FROM=
SMTP_PASS=
