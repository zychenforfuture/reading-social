{
  "name": "cross-doc-comments",
  "version": "0.1.0",
  "private": true,
  "description": "跨文档协同评论系统 - 评论跟着内容走",
  "scripts": {
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @collab/api build",
    "build:web": "pnpm --filter @collab/web build",
    "lint": "pnpm -r lint",
    "test": "./scripts/test.sh",
    "test:quick": "pnpm --filter @collab/api test",
    "test:watch": "pnpm --filter @collab/api test:watch"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
